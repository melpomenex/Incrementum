{
  "name": "incrementum-tauri",
  "private": true,
  "version": "1.15.3",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 vite",
    "dev:pwa": "NODE_OPTIONS=--max-old-space-size=4096 vite --mode pwa",
    "prebuild": "node scripts/download-sidecars.js",
    "build": "vite build",
    "build:pwa": "vite build --mode pwa",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
    "preview:pwa": "vite preview --mode pwa",
    "tauri": "bash scripts/tauri-wrapper.sh",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "tauri:build:linux": "tauri build --bundles deb,rpm",
    "tauri:build:linux:appimage": "bash scripts/ci-build-appimage.sh",
    "tauri:build:linux:deb": "tauri build --bundles deb",
    "tauri:build:macos": "tauri build --bundles app",
    "tauri:build:macos:dmg": "tauri build --bundles dmg",
    "tauri:build:windows": "tauri build --bundles msi",
    "tauri:build:windows:nsis": "tauri build --bundles nsis",
    "tauri:android:init": "tauri android init --ci",
    "tauri:android:dev": "tauri android dev --target aarch64",
    "tauri:android:build": "tauri android build --ci --target aarch64 --apk",
    "tauri:ios:init": "tauri ios init --ci",
    "tauri:ios:dev:sim": "tauri ios dev --target aarch64-sim",
    "tauri:ios:build:sim": "tauri ios build --ci --target aarch64-sim",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "release:downloads": "bash scripts/release-downloads.sh",
    "release:downloads:graph": "bash scripts/release-downloads.sh --graph",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:wave5:regression": "vitest run src/stores/__tests__/reviewStore.test.ts src/utils/__tests__/fsrsScope.test.ts src/utils/__tests__/reviewInteractions.test.ts src/utils/__tests__/semanticGrading.test.ts src/utils/__tests__/cardQuality.test.ts src/utils/__tests__/referenceImport.test.ts src/lib/__tests__/pluginHost.test.ts src/utils/__tests__/wave4Social.test.ts src/utils/__tests__/reviewAccessibility.test.ts",
    "test:wave5:performance": "vitest run src/utils/__tests__/wave5Performance.test.ts src/utils/__tests__/performance.test.tsx"
  },
  "dependencies": {

#!/bin/bash
# AppRun script for Incrementum AppImage
# This wrapper sets environment variables to fix webkit2gtk issues and enable YouTube playback

# === WebKit Configuration ===
# Disable sandbox (required for YouTube iframe playback on WebKitGTK 2.44+)
export WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1

# Disable DMA-BUF renderer to fix EGL display issues
export WEBKIT_DISABLE_DMABUF_RENDERER=1

# Disable compositing mode to prevent video freezing
export WEBKIT_DISABLE_COMPOSITING_MODE=1

# Disable hardware acceleration (required for YouTube video playback)
export WEBKIT_DISABLE_HARDWARE_ACCELERATION=1

# === GStreamer Configuration ===
# Use bundled GStreamer plugins for codec support (H.264, etc.)
APPDIR="${APPDIR:-$(dirname "$(readlink -f "$0")")}"

# Set GStreamer plugin path to bundled plugins if they exist
BUNDLED_GST_PATH="$APPDIR/usr/lib/gstreamer-1.0"
if [ -d "$BUNDLED_GST_PATH" ]; then
    export GST_PLUGIN_SYSTEM_PATH_1_0="$BUNDLED_GST_PATH"
    export GST_PLUGIN_PATH="$BUNDLED_GST_PATH"
fi

# Prefer automatic audio sink selection so PipeWire/Pulse/ALSA can all work
export GST_AUDIOSINK="${GST_AUDIOSINK:-autoaudiosink}"
export AUDIOSINK="${AUDIOSINK:-autoaudiosink}"

# === Run Application ===
exec "$APPDIR/usr/bin/incrementum-tauri" "$@"

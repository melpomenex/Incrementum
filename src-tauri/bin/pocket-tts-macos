#!/bin/sh
set -eu

unset LD_LIBRARY_PATH LD_PRELOAD PYTHONHOME PYTHONPATH

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/pocket-tts-runtime/macos"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"

find_python() {
  if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
    echo "$RUNTIME_PY"
    return
  fi
  for p in python3 python; do
    if command -v "$p" >/dev/null 2>&1; then
      echo "$p"
      return
    fi
  done
  echo ""
}

PYTHON="$(find_python)"
if [ -z "$PYTHON" ]; then
  echo "error: Python not found" >&2
  exit 1
fi

if [ -d "$RUNTIME_SITE" ]; then
  export PYTHONHOME="$RUNTIME_BASE/python"
  export PYTHONPATH="$RUNTIME_SITE"
fi

TEXT_FILE=""
NEW_ARGS=""
skip=false
for arg in "$@"; do
  if "$skip"; then
    skip=false
    TEXT_FILE="$arg"
    continue
  fi
  case "$arg" in
    --text-file)
      skip=true
      ;;
    --text-file=*)
      TEXT_FILE="${arg#--text-file=}"
      ;;
    *)
      NEW_ARGS="$NEW_ARGS
$arg"
      ;;
  esac
done

if [ -n "$TEXT_FILE" ] && [ -f "$TEXT_FILE" ]; then
  ARGS_FILE="$(mktemp "${TMPDIR:-/tmp}/pocket-tts-args-XXXXXX.json")"
  "$PYTHON" -c "
import json, sys
args = ['pocket_tts', 'generate']
for a in sys.argv[1:]:
    args.append(a)
with open('$ARGS_FILE', 'w') as f:
    json.dump(args, f)
" $NEW_ARGS
  WRAPPER="$(mktemp "${TMPDIR:-/tmp}/pocket-tts-wrapper-XXXXXX.py")"
  printf '%s\n' \
    'import sys, os, json' \
    "with open('$ARGS_FILE') as f: sys.argv = json.load(f)" \
    "sys.argv.append('--text')" \
    "sys.argv.append(open('$TEXT_FILE').read())" \
    "os.unlink('$ARGS_FILE')" \
    "os.unlink('$TEXT_FILE')" \
    "os.unlink('$WRAPPER')" \
    'from pocket_tts.__main__ import cli_app' \
    'cli_app()' \
    > "$WRAPPER"
  exec "$PYTHON" "$WRAPPER"
else
  exec "$PYTHON" -m pocket_tts "$@"
fi

#!/bin/sh
set -eu
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/pocket-tts-runtime/macos"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"

find_python() {
  if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
    echo "$RUNTIME_PY"
    return
  fi
  for p in python3 python; do
    if command -v "$p" >/dev/null 2>&1; then
      echo "$p"
      return
    fi
  done
  echo ""
}

PYTHON="$(find_python)"
if [ -z "$PYTHON" ]; then
  echo "error: Python not found" >&2
  exit 1
fi

# Check for --text-file flag to avoid ARG_MAX issues with long text
TEXT_FILE=""
REMAINING_ARGS=""
skip=false
for arg in "$@"; do
  if "$skip"; then
    skip=false
    TEXT_FILE="$arg"
    continue
  fi
  case "$arg" in
    --text-file)
      skip=true
      ;;
    --text-file=*)
      TEXT_FILE="${arg#--text-file=}"
      ;;
    *)
      REMAINING_ARGS="$REMAINING_ARGS $(printf '%s' "$arg" | sed "s/'/'\\\\''/g")"
      ;;
  esac
done

if [ -n "$TEXT_FILE" ] && [ -f "$TEXT_FILE" ]; then
  TEXT_FILE_ESC="$(printf '%s' "$TEXT_FILE" | sed "s/'/'\\\\''/g")"
  if [ -d "$RUNTIME_SITE" ]; then
    export PYTHONHOME="$RUNTIME_BASE/python"
    export PYTHONPATH="$RUNTIME_SITE"
  fi
  exec "$PYTHON" -c "
import sys, os
sys.argv = ['pocket_tts', 'generate'$REMAINING_ARGS, '--text', open('$TEXT_FILE_ESC').read()]
os.unlink('$TEXT_FILE_ESC')
from pocket_tts.__main__ import cli_app
cli_app()
"
else
  if [ -d "$RUNTIME_SITE" ]; then
    export PYTHONHOME="$RUNTIME_BASE/python"
    export PYTHONPATH="$RUNTIME_SITE"
    exec "$PYTHON" -m pocket_tts "$@"
  fi
  if [ -n "${HOME:-}" ] && [ -d "$HOME/.local/bin" ]; then
    PATH="$PATH:$HOME/.local/bin"
  fi
  PATH="$PATH:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  export PATH
  for CANDIDATE in "${HOME:-}/.local/bin/pocket-tts" /usr/local/bin/pocket-tts /usr/bin/pocket-tts /bin/pocket-tts; do
    if [ -x "$CANDIDATE" ]; then
      exec "$CANDIDATE" "$@"
    fi
  done
  exec pocket-tts "$@"
fi

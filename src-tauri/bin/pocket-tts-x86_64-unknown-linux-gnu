#!/bin/sh
set -eu
# Check for --text-file and transform into --text by reading the file
TEXT_FILE=""
skip=false
argc=$#
i=0
while [ $i -lt $argc ]; do
  arg="$1"
  shift
  i=$((i + 1))
  if $skip; then
    skip=false
    TEXT_FILE="$arg"
    continue
  fi
  case "$arg" in
    --text-file)
      skip=true
      ;;
    --text-file=*)
      TEXT_FILE="${arg#--text-file=}"
      ;;
    *)
      set -- "$@" "$arg"
      ;;
  esac
done
if [ -n "$TEXT_FILE" ] && [ -f "$TEXT_FILE" ]; then
  set -- "$@" "--text" "$(cat "$TEXT_FILE")"
  rm -f "$TEXT_FILE"
fi
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/pocket-tts-runtime/x86_64-unknown-linux-gnu"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"
if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
  export PYTHONHOME="$RUNTIME_BASE/python"
  export PYTHONPATH="$RUNTIME_SITE"
  exec "$RUNTIME_PY" -m pocket_tts "$@"
fi
if [ -n "${HOME:-}" ] && [ -d "$HOME/.local/bin" ]; then
  PATH="$PATH:$HOME/.local/bin"
fi
PATH="$PATH:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH
for CANDIDATE in "${HOME:-}/.local/bin/pocket-tts" /usr/local/bin/pocket-tts /usr/bin/pocket-tts /bin/pocket-tts; do
  if [ -x "$CANDIDATE" ]; then
    if [ "$(dirname -- "$CANDIDATE")" != "$SCRIPT_DIR" ]; then
      exec "$CANDIDATE" "$@"
    fi
  fi
done
RESOLVED_PATH=""
OLD_IFS="$IFS"
IFS=":"
for DIR in $PATH; do
  if [ -x "$DIR/pocket-tts" ] && [ ! -d "$DIR/pocket-tts" ]; then
    if [ "$DIR" != "$SCRIPT_DIR" ]; then
      RESOLVED_PATH="$DIR/pocket-tts"
      break
    fi
  fi
done
IFS="$OLD_IFS"
if [ -n "$RESOLVED_PATH" ]; then
  exec "$RESOLVED_PATH" "$@"
else
  echo "error: pocket_tts is not installed" >&2
  echo "Install it with:  uv tool install pocket-tts" >&2
  echo "Or with pip:      pip install pocket-tts" >&2
  exit 1
fi

#!/bin/sh
# Pocket TTS Wrapper Script for Linux
#
# This script wraps the system-installed pocket-tts CLI for use as a Tauri sidecar.

set -eu

# Strip AppImage environment variables that interfere with Python and readline.
unset APPDIR APPIMAGE OWD LD_LIBRARY_PATH LD_PRELOAD PYTHONHOME PYTHONPATH

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/pocket-tts-runtime/x86_64-unknown-linux-gnu"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"

# Prepend common user-local directories to PATH so that pocket_tts
# installed via `uv tool install` or `pip install --user` is found even
# when the app inherits a minimal PATH (e.g. desktop entry / AppImage).
enhance_path() {
  _home_local="$HOME/.local/bin"
  _uv_tool="$HOME/.local/share/uv/tools/pocket-tts/bin"
  [ -d "$_home_local" ] && PATH="$_home_local:$PATH"
  [ -d "$_uv_tool" ] && PATH="$_uv_tool:$PATH"
  export PATH
}

find_python() {
  if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
    echo "$RUNTIME_PY"
    return
  fi
  for p in python3 python; do
    if command -v "$p" >/dev/null 2>&1; then
      echo "$p"
      return
    fi
  done
  echo ""
}

enhance_path

PYTHON="$(find_python)"
if [ -z "$PYTHON" ]; then
  echo "error: Python not found" >&2
  echo "To install: uv tool install pocket-tts" >&2
  exit 1
fi

# Verify that the pocket_tts module is importable.
if ! "$PYTHON" -c "import pocket_tts" 2>/dev/null; then
  echo "error: pocket_tts is not installed for $PYTHON" >&2
  echo "Install it with:  uv tool install pocket-tts" >&2
  echo "Or with pip:      pip install pocket-tts" >&2
  exit 1
fi

if [ -d "$RUNTIME_SITE" ]; then
  export PYTHONHOME="$RUNTIME_BASE/python"
  export PYTHONPATH="$RUNTIME_SITE"
fi

# Check for --text-file and transform into --text by writing a Python wrapper.
# We write args to a temp file as JSON to avoid all shell quoting issues.
TEXT_FILE=""
NEW_ARGS=""
skip=false
for arg in "$@"; do
  if "$skip"; then
    skip=false
    TEXT_FILE="$arg"
    continue
  fi
  case "$arg" in
    --text-file)
      skip=true
      ;;
    --text-file=*)
      TEXT_FILE="${arg#--text-file=}"
      ;;
    *)
      NEW_ARGS="$NEW_ARGS
$arg"
      ;;
  esac
done

if [ -n "$TEXT_FILE" ] && [ -f "$TEXT_FILE" ]; then
  ARGS_FILE="$(mktemp "${TMPDIR:-/tmp}/pocket-tts-args-XXXXXX.json")"
  # Build JSON array of args using Python itself (safe quoting)
  "$PYTHON" -c "
import json, sys
args = ['pocket_tts']
for a in sys.argv[1:]:
    args.append(a)
with open('$ARGS_FILE', 'w') as f:
    json.dump(args, f)
" $NEW_ARGS
  # Write a Python wrapper that reads args from JSON and text from file
  WRAPPER="$(mktemp "${TMPDIR:-/tmp}/pocket-tts-wrapper-XXXXXX.py")"
  printf '%s\n' \
    'import sys, os, json' \
    "with open('$ARGS_FILE') as f: sys.argv = json.load(f)" \
    "sys.argv.append('--text')" \
    "sys.argv.append(open('$TEXT_FILE').read())" \
    "os.unlink('$ARGS_FILE')" \
    "os.unlink('$TEXT_FILE')" \
    "os.unlink('$WRAPPER')" \
    'from pocket_tts.__main__ import cli_app' \
    'cli_app()' \
    > "$WRAPPER"
  exec "$PYTHON" "$WRAPPER"
else
  exec "$PYTHON" -m pocket_tts "$@"
fi

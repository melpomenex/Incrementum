#!/bin/sh
set -eu
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/notebooklm-runtime/x86_64-unknown-linux-gnu"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"
RUNTIME_PLAYWRIGHT="$RUNTIME_BASE/playwright"
if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
  export PYTHONHOME="$RUNTIME_BASE/python"
  export PYTHONPATH="$RUNTIME_SITE"
  export PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-$RUNTIME_PLAYWRIGHT}"
  exec "$RUNTIME_PY" -m notebooklm.notebooklm_cli "$@"
fi
LEGACY_BUNDLED="$SCRIPT_DIR/notebooklm-runtime/x86_64-unknown-linux-gnu/.venv/bin/notebooklm"
if [ -x "$LEGACY_BUNDLED" ]; then
  exec "$LEGACY_BUNDLED" "$@"
fi
if [ -n "${HOME:-}" ] && [ -d "$HOME/.local/bin" ]; then
  PATH="$PATH:$HOME/.local/bin"
fi
PATH="$PATH:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH
for CANDIDATE in "${HOME:-}/.local/bin/notebooklm" /usr/local/bin/notebooklm /usr/bin/notebooklm /bin/notebooklm; do
  if [ -x "$CANDIDATE" ]; then
    if [ "$(dirname -- "$CANDIDATE")" != "$SCRIPT_DIR" ]; then
      exec "$CANDIDATE" "$@"
    fi
  fi
done

RESOLVED_PATH=""
OLD_IFS="$IFS"
IFS=":"
for DIR in $PATH; do
  if [ -x "$DIR/notebooklm" ] && [ ! -d "$DIR/notebooklm" ]; then
    if [ "$DIR" != "$SCRIPT_DIR" ]; then
      RESOLVED_PATH="$DIR/notebooklm"
      break
    fi
  fi
done
IFS="$OLD_IFS"

if [ -n "$RESOLVED_PATH" ]; then
  exec "$RESOLVED_PATH" "$@"
else
  echo "error: notebooklm is not installed" >&2
  echo "Install it with:  pip install notebooklm-py" >&2
  exit 1
fi

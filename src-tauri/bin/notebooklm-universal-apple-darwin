#!/bin/sh
set -eu
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RUNTIME_BASE="$SCRIPT_DIR/notebooklm-runtime/universal-apple-darwin"
RUNTIME_PY="$RUNTIME_BASE/python/bin/python3"
RUNTIME_SITE="$RUNTIME_BASE/site-packages"
RUNTIME_PLAYWRIGHT="$RUNTIME_BASE/playwright"
if [ -x "$RUNTIME_PY" ] && [ -d "$RUNTIME_SITE" ]; then
  export PYTHONHOME="$RUNTIME_BASE/python"
  export PYTHONPATH="$RUNTIME_SITE"
  export PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH:-$RUNTIME_PLAYWRIGHT}"
  exec "$RUNTIME_PY" -m notebooklm.notebooklm_cli "$@"
fi
LEGACY_BUNDLED="$SCRIPT_DIR/notebooklm-runtime/universal-apple-darwin/.venv/bin/notebooklm"
if [ -x "$LEGACY_BUNDLED" ]; then
  exec "$LEGACY_BUNDLED" "$@"
fi
if [ -n "${HOME:-}" ] && [ -d "$HOME/.local/bin" ]; then
  PATH="$PATH:$HOME/.local/bin"
fi
PATH="$PATH:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export PATH
for CANDIDATE in "${HOME:-}/.local/bin/notebooklm" /usr/local/bin/notebooklm /usr/bin/notebooklm /bin/notebooklm; do
  if [ -x "$CANDIDATE" ]; then
    exec "$CANDIDATE" "$@"
  fi
done
exec notebooklm "$@"

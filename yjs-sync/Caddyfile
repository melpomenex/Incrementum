# Replace with your domain, e.g. sync.readsync.org
{$YJS_SYNC_HOSTNAME} {
  encode zstd gzip

  @ws {
    header Connection *Upgrade*
    header Upgrade websocket
  }

  @files {
    path /files/*
  }

  respond /health 200

  # 100MB per file upload (enforced again by multer in file-service).
  request_body @files {
    max_size 100MB
  }

  reverse_proxy @files file-service:8787
  reverse_proxy @ws yjs-sync:1234
  reverse_proxy yjs-sync:1234
}

{$TRANSCRIPT_HOSTNAME} {
  encode zstd gzip
  reverse_proxy transcript-service:8766
}

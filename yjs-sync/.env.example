# Domain configuration
YJS_SYNC_HOSTNAME=sync.readsync.org
TRANSCRIPT_HOSTNAME=transcripts.readsync.org

# Transcript service configuration
TRANSCRIPT_API_KEY=change-me-in-production

# Proxy configuration (for yt-dlp to bypass YouTube restrictions)
PROXY_HOST='proxy host here'
PROXY_PORT='port'
PROXY_USER='username here'
PROXY_PASS='password here'

# VPS Deployment Configuration
VPS_HOST=12.34.56.78
VPS_USER=ubuntu
# REMOTE_DIR=/home/ubuntu/yjs-sync

# Encrypted-frame rolling log (task 1.8b). When set, the relay durably stores
# recent encrypted sync frames so async state sync works (device A writes, device
# B downloads later when A is offline). Leave unset to disable persistence.
# Optional tuning (defaults shown):
#   FRAME_LOG_MAX_BYTES=67108864    (per-room cap, 64 MiB)
#   FRAME_LOG_MAX_FRAME_BYTES=16777216  (reject frames larger than 16 MiB)
#   FRAME_LOG_MAX_DAYS=30           (time-GC window)
FRAME_LOG_DIR=/data/frame-log

